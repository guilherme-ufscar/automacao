# ============================================================
# PORTAS EXPOSTAS NO HOST — mude se já estiverem em uso
# Apenas o lado esquerdo do mapeamento host:container muda.
# A comunicação ENTRE containers usa sempre as portas internas.
# ============================================================
PORT_AGENT=3000
PORT_EVOLUTION=8080
PORT_POSTGRES=5432

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# Evolution API
# ============================================================
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=karina
# URL interna (container → container): porta interna é sempre 8080
EVOLUTION_BASE_URL=http://evolution:8080

# ============================================================
# PostgreSQL
# ============================================================
# Host interno (container → container): sempre "postgres"
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=alcantara
POSTGRES_USER=alcantara
POSTGRES_PASSWORD=senha_segura_aqui

# ============================================================
# App
# ============================================================
NODE_ENV=production
